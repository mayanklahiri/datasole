{
  "name": "datasole",
  "version": "1.0.0",
  "description": "High-performance, binary-framed, realtime full-stack TypeScript framework with Web Worker transport, JSON Patch state sync, and pluggable backends.",
  "main": "./dist/shared/index.cjs",
  "module": "./dist/shared/index.mjs",
  "types": "./dist/shared/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.mjs",
      "require": "./dist/shared/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/datasole.mjs",
      "require": "./dist/client/datasole.cjs",
      "browser": "./dist/client/datasole.mjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.cjs"
    },
    "./client/worker": "./dist/client/datasole-worker.iife.min.js"
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client/index.d.ts"
      ],
      "server": [
        "dist/server/index.d.ts"
      ],
      "*": [
        "dist/shared/index.d.ts"
      ]
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs && npm run build:types",
    "build:types": "tsc -p build/tsconfig.declarations.json",
    "build:client": "rollup -c build/rollup.client.mjs",
    "build:server": "rollup -c build/rollup.server.mjs",
    "build:worker": "rollup -c build/rollup.worker.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "npm run build && npx playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:debug": "npm run build && npx playwright test --config test/e2e/playwright.config.ts --headed --debug",
    "lint": "eslint 'src/**/*.ts' 'test/unit/**/*.ts' && tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' '*.json' '*.mjs'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' '*.json' '*.mjs'",
    "clean": "rm -rf dist/ reports/ coverage/ docs-site/dist/ docs/.vitepress/cache/",
    "gate": "npm run clean && npm run format:check && npm run lint && npm run build && npm run test -- --coverage && npm run test:e2e && npm run collect-metrics && npm run docs:build && npm run gate:summary",
    "gate:summary": "tsx build/gate-summary.ts",
    "dist": "npm run gate",
    "collect-metrics": "tsx build/collect-metrics.ts",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run gate",
    "prepare": "husky && npx playwright install chromium || true"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "test/unit/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,mjs,cjs,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayanklahiri/datasole.git"
  },
  "keywords": [
    "websocket",
    "realtime",
    "binary",
    "typescript",
    "full-stack",
    "rpc",
    "state-sync",
    "json-patch",
    "web-worker",
    "shared-array-buffer",
    "express",
    "nestjs",
    "vue",
    "react"
  ],
  "author": "Mayank Lahiri <mlahiri@gmail.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/mayanklahiri/datasole/issues"
  },
  "homepage": "https://mayanklahiri.github.io/datasole/",
  "dependencies": {
    "fast-json-patch": "^3.1.1",
    "pako": "^2.1.0",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pako": "^2.0.4",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "marked": "^17.0.4",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.4.0",
    "serve": "^14.2.6",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/websockets": ">=10.0.0",
    "ioredis": ">=5.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/websockets": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
