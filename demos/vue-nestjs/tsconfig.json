{
  "extends": "../../build/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "rootDir": ".",
    "noEmit": true,
    "exactOptionalPropertyTypes": false
  },
  "include": ["client/**/*.ts", "client/**/*.vue", "vite-env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
